<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Prestige Homes</title>

<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family: Arial, sans-serif;
}

body{
  background:#0f172a;
  color:white;
}

/* NAV */
nav{
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:20px;
  background:#111827;
}

nav h1{
  font-size:18px;
  color:#38bdf8;
}

nav a{
  color:white;
  margin-left:15px;
  text-decoration:none;
  font-size:14px;
}

/* HERO */
.hero{
  padding:60px 20px;
  text-align:center;
  background:linear-gradient(to bottom, #111827, #0f172a);
}

.hero h2{
  font-size:28px;
  margin-bottom:10px;
}

.hero p{
  color:#cbd5e1;
  font-size:14px;
  margin-bottom:20px;
}

.btn{
  background:#38bdf8;
  padding:10px 18px;
  border:none;
  color:#000;
  border-radius:6px;
  font-weight:bold;
}

/* SECTION */
.section{
  padding:30px 20px;
}

.card-container{
  display:flex;
  flex-direction:column;
  gap:15px;
  margin-top:15px;
}

.card{
  background:#1e293b;
  padding:15px;
  border-radius:10px;
}

.card h3{
  color:#38bdf8;
  margin-bottom:5px;
}

/* FOOTER */
footer{
  text-align:center;
  padding:20px;
  font-size:12px;
  color:#94a3b8;
  margin-top:20px;
}

@media(min-width:768px){
  .card-container{
    flex-direction:row;
  }
}
</style>

</head>
<body>

<nav>
  <h1>Prestige Homes</h1>
  <div>
    <a href="#">Home</a>
    <a href="#">Listings</a>
    <a href="#">Contact</a>
  </div>
</nav>

<section class="hero">
  <h2>Luxury Living Starts Here</h2>
  <p>Find your dream home with premium comfort, modern design, and trusted service.</p>
  <button class="btn">Explore Homes</button>
</section>

<section class="section">
  <h2>Featured Properties</h2>

  <div class="card-container">

    <div class="card">
      <h3>Modern Apartment</h3>
      <p>2 Bed • Lekki Phase 1 • ₦85M</p>
    </div>

    <div class="card">
      <h3>Luxury Duplex</h3>
      <p>4 Bed • Ikoyi • ₦250M</p>
    </div>

    <div class="card">
      <h3>Smart Villa</h3>
      <p>5 Bed • Ajah • ₦180M</p>
    </div>

  </div>
</section>

<footer>
  © 2026 Prestige Homes. All rights reserved.
</footer>

</body>
</html>
